---
import BaseLayout from './BaseLayout.astro';
import { Button } from '@/components/ui/Button';

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <!-- Public Navbar -->
  <header id="public-header" class="fixed top-0 z-50 w-full transition-all duration-300 bg-transparent border-transparent" data-scrolled-classes="bg-white/85 backdrop-blur-md border-b border-slate-200/50 shadow-sm">
    <div class="container flex h-16 items-center justify-between">
      <div class="flex items-center gap-2">
        <a href="/" class="flex flex-col gap-1">
          <img src="/logo-horizontal.png" alt="BAHARI" class="h-8 md:h-10 object-contain object-left" />
        </a>
      </div>
      <nav class="hidden lg:flex items-center gap-8 text-sm font-bold text-[#0f3e68]">
        <a href="/" class="hover:text-primary transition-colors border-b-2 border-[#0a4595] pb-1">Beranda</a>
        <a href="/#tentang" class="hover:text-primary transition-colors">Tentang</a>
        <a href="/#fitur" class="hover:text-primary transition-colors">Fitur</a>
        <a href="/#untuk-siapa" class="hover:text-primary transition-colors">Untuk Siapa</a>
        <a href="/#dampak" class="hover:text-primary transition-colors">Dampak</a>
        <a href="/#blog" class="hover:text-primary transition-colors">Blog</a>
        <a href="/#kontak" class="hover:text-primary transition-colors">Kontak</a>
      </nav>
      
      <div class="hidden lg:flex items-center gap-3">
        <a href="/login">
          <Button variant="default" className="bg-[#083575] hover:bg-[#0a4595] text-white rounded-lg px-6 font-semibold shadow-md">Masuk</Button>
        </a>
        <a href="/register">
          <Button variant="outline" className="border-[#0a4595] text-[#0a4595] hover:bg-blue-50 rounded-lg px-6 font-semibold bg-white/50 backdrop-blur-sm">Daftar</Button>
        </a>
      </div>
    </div>
  </header>

  <!-- Page Content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Public Footer -->
  <footer class="bg-[#0a2036] text-white pt-16 pb-8 border-t-8 border-[#0f3e68]">
    <div class="container mx-auto px-4 md:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-8 lg:gap-12 mb-12">
        {/* Col 1: Logo & Subtext */}
        <div class="lg:col-span-2 space-y-4">
          <img src="/logo-horizontal.png" alt="BAHARI" class="h-12 md:h-14 object-contain object-left brightness-0 invert" />
          <p class="text-sm text-slate-400 leading-relaxed max-w-xs pt-2">
            Dari Laut untuk Kehidupan Berkelanjutan
          </p>
        </div>
        
        {/* Col 2: Platform */}
        <div class="space-y-6">
          <h4 class="font-bold font-['Outfit'] text-white">Platform</h4>
          <ul class="space-y-3 text-sm text-slate-400">
            <li><a href="/marketplace" class="hover:text-white transition-colors">Marketplace</a></li>
            <li><a href="/for-coop" class="hover:text-white transition-colors">Untuk Koperasi</a></li>
            <li><a href="/features" class="hover:text-white transition-colors">Fitur</a></li>
            <li><a href="/pricing" class="hover:text-white transition-colors">Harga</a></li>
          </ul>
        </div>
        
        {/* Col 3: Informasi */}
        <div class="space-y-6">
          <h4 class="font-bold font-['Outfit'] text-white">Informasi</h4>
          <ul class="space-y-3 text-sm text-slate-400">
            <li><a href="/about" class="hover:text-white transition-colors">Tentang Kami</a></li>
            <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
            <li><a href="/careers" class="hover:text-white transition-colors">Karir</a></li>
            <li><a href="/faq" class="hover:text-white transition-colors">FAQ</a></li>
          </ul>
        </div>
        
        {/* Col 4: Bantuan */}
        <div class="space-y-6">
          <h4 class="font-bold font-['Outfit'] text-white">Bantuan</h4>
          <ul class="space-y-3 text-sm text-slate-400">
            <li><a href="/support" class="hover:text-white transition-colors">Pusat Bantuan</a></li>
            <li><a href="/terms" class="hover:text-white transition-colors">Syarat & Ketentuan</a></li>
            <li><a href="/privacy" class="hover:text-white transition-colors">Kebijakan Privasi</a></li>
          </ul>
        </div>
        
        {/* Col 5: Kontak & Socials */}
        <div class="space-y-6">
          <h4 class="font-bold font-['Outfit'] text-white">Kontak</h4>
          <ul class="space-y-3 text-sm text-slate-400">
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <span>halo@bahari.co.id</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
              <span>+62 812-3456-7890</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Kendari, Sulawesi Tenggara</span>
            </li>
          </ul>
          
          <div class="flex items-center gap-3 pt-2">
            <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-white hover:text-[#0f3e68] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-white hover:text-[#0f3e68] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </a>
            <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-white hover:text-[#0f3e68] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
            </a>
          </div>
        </div>
      </div>
      
      <div class="flex flex-col md:flex-row items-center justify-between pt-8 border-t border-white/10 text-xs text-slate-500">
        <p>&copy; 2025 BAHARI. All rights reserved.</p>
        <p class="mt-4 md:mt-0 font-medium">bahari.co.id</p>
      </div>
    </div>
  </footer>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const header = document.getElementById('public-header');
      if (!header) return;
      
      const scrolledClasses = header.getAttribute('data-scrolled-classes')?.split(' ') || [];
      const transparentClasses = ['bg-transparent', 'border-transparent'];
      
      const handleScroll = () => {
        if (window.scrollY > 20) {
          header.classList.remove(...transparentClasses);
          header.classList.add(...scrolledClasses);
        } else {
          header.classList.remove(...scrolledClasses);
          header.classList.add(...transparentClasses);
        }
      };
      
      handleScroll();
      window.addEventListener('scroll', handleScroll, { passive: true });
    });
  </script>
</BaseLayout>
