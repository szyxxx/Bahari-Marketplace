---
import BaseLayout from './BaseLayout.astro';
import { cn } from "@/lib/utils";

interface Props {
  title?: string;
}

const { title } = Astro.props;

const menuItems = [
  { label: "Platform Overview", href: "/admin", icon: "Activity" },
  { label: "Koperasi", href: "/admin/cooperatives", icon: "Building" },
  { label: "Global Users", href: "/admin/users", icon: "Users" },
  { label: "Pengaturan", href: "/admin/settings", icon: "Settings" },
];
---

<BaseLayout title={title}>
  <div class="flex min-h-screen bg-slate-50 dark:bg-slate-950">
    {/* Admin Sidebar - Darker Theme to distinguish from Cooperative Dashboard */}
    <aside class="w-64 border-r bg-slate-900 text-slate-100 hidden md:flex flex-col">
      <div class="p-6">
        <h2 class="text-xl font-bold tracking-tight font-['Outfit'] flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-teal-400"><path d="M2 12h4l2-9 5 18 5-18 2 9h4"/></svg>
          BAHARI Admin
        </h2>
      </div>
      <nav class="flex-1 px-4 space-y-1 mt-4">
        {menuItems.map((item) => (
          <a
            href={item.href}
            class="flex items-center gap-3 rounded-md px-3 py-2.5 text-sm font-medium text-slate-300 hover:bg-slate-800 hover:text-white transition-colors"
          >
            <span class="w-4 h-4 bg-slate-700 rounded-sm" />
            {item.label}
          </a>
        ))}
      </nav>
      <div class="p-4 border-t border-slate-800">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center font-bold text-xs">SA</div>
          <div class="text-sm">
            <p class="font-medium">Super Admin</p>
            <p class="text-xs text-slate-400">admin@bahari.id</p>
          </div>
        </div>
      </div>
    </aside>

    <div class="flex-1 flex flex-col min-w-0">
      <header class="h-16 border-b bg-white dark:bg-slate-900 flex items-center justify-between px-6">
        <h1 class="text-lg font-semibold md:hidden">BAHARI Admin</h1>
        <div class="ml-auto">
          {/* Top nav actions */}
        </div>
      </header>
      <main class="flex-1 overflow-auto p-8">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>
