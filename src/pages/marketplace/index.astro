---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { MarketplaceView } from '@/components/marketplace/MarketplaceView';
---

<PublicLayout title="Marketplace - BAHARI">
  <div class="bg-muted/30 border-b">
    <div class="container py-8 md:py-12">
      <h1 class="text-3xl md:text-4xl font-bold font-['Outfit'] tracking-tight mb-2">B2B Marketplace Pesisir</h1>
      <p class="text-muted-foreground max-w-2xl">
        Beli komoditas laut dan pesisir langsung dari Koperasi Desa. Terverifikasi, berkualitas, dan mendukung keberlanjutan.
      </p>
    </div>
  </div>
  
  <MarketplaceView client:load />
</PublicLayout>
