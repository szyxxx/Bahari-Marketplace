---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { ListingDetail } from '@/components/marketplace/ListingDetail';

export function getStaticPaths() {
  // In SSR mode, we wouldn't need getStaticPaths.
  // Since Astro is in default static mode, we either configure SSR or mock paths.
  // For MVP scaffold, we'll configure dynamic route fallback or just mock a few IDs.
  return [
    { params: { id: "1" } },
    { params: { id: "2" } },
    { params: { id: "3" } }
  ];
}

const { id } = Astro.params;
---

<PublicLayout>
  <ListingDetail id={id as string} client:load />
</PublicLayout>
