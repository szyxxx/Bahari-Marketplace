---
---

<section class="py-24 bg-slate-50">
  <div class="container mx-auto px-4 md:px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold font-['Outfit'] text-[#0f3e68] mb-4">
        Dampak Nyata BAHARI
      </h2>
      <p class="text-slate-600 text-lg">
        Bersama membangun ekonomi pesisir yang lebih kuat dan berkelanjutan
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      
      {/* Card 1 */}
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex items-start gap-4 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-blue-50 text-[#0f3e68] flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div>
          <h3 class="font-bold text-2xl text-slate-800 font-['Outfit']">70,38%</h3>
          <p class="text-sm font-medium text-slate-700 mt-1">Penduduk miskin berasal dari desa pesisir di Sultra</p>
          <p class="text-xs text-slate-400 mt-2">BPS, 2025</p>
        </div>
      </div>

      {/* Card 2 */}
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex items-start gap-4 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
        </div>
        <div>
          <h3 class="font-bold text-2xl text-slate-800 font-['Outfit']">Rp125-225 T</h3>
          <p class="text-sm font-medium text-slate-700 mt-1">Kerugian akibat limbah plastik laut per tahun</p>
          <p class="text-xs text-slate-400 mt-2">BRIN, 2024</p>
        </div>
      </div>

      {/* Card 3 */}
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex items-start gap-4 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-green-50 text-green-600 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </div>
        <div>
          <h3 class="font-bold text-2xl text-slate-800 font-['Outfit']">106,79</h3>
          <p class="text-sm font-medium text-slate-700 mt-1">Nilai Tukar Nelayan (NTN) Sultra namun masih rentan</p>
          <p class="text-xs text-slate-400 mt-2">BPS, 2024</p>
        </div>
      </div>

      {/* Card 4 */}
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex items-start gap-4 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-blue-50 text-[#0f3e68] flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div>
          <h3 class="font-bold text-2xl text-slate-800 font-['Outfit']">Rp7,1 Triliun</h3>
          <p class="text-sm font-medium text-slate-700 mt-1">Nilai produksi hasil tangkapan Sultra per tahun</p>
          <p class="text-xs text-slate-400 mt-2">DKP Sultra, 2024</p>
        </div>
      </div>

    </div>
  </div>
</section>
