---
import { Button } from "@/components/ui/Button";
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4 md:px-6">
    <div class="bg-[#0f3e68] rounded-3xl p-8 md:p-12 lg:p-16 flex flex-col xl:flex-row items-center gap-12 overflow-hidden relative shadow-xl">
      
      {/* Decorative background elements */}
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-400/10 rounded-full blur-3xl -translate-x-1/2 translate-y-1/2"></div>

      {/* Left Content */}
      <div class="xl:w-1/3 z-10 text-center xl:text-left">
        <h2 class="text-3xl md:text-4xl font-bold font-['Outfit'] text-white leading-tight mb-6">
          Gotong Royong Digital untuk Laut yang Lestari
        </h2>
        <p class="text-blue-100 text-lg mb-8 leading-relaxed">
          BAHARI menghubungkan nelayan, koperasi, pasar, dan insentif lingkungan dalam satu ekosistem digital yang saling menguatkan.
        </p>
        <Button variant="outline" className="bg-white text-[#0f3e68] border-white hover:bg-slate-50 hover:text-[#0f3e68] rounded-full px-8 py-6 text-base gap-2 font-semibold mx-auto xl:mx-0">
          Pelajari Cara Kerja
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m10 8 4 4-4 4"/></svg>
        </Button>
      </div>

      {/* Right Diagram */}
      <div class="xl:w-2/3 z-10 w-full relative">
        <div class="bg-white rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-4 shadow-lg border border-slate-100 relative">
          
          <div class="flex flex-col items-center text-center gap-3">
            <div class="w-16 h-16 bg-blue-50 text-[#0f3e68] rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <span class="font-semibold text-slate-800 text-sm">Nelayan</span>
          </div>

          <svg class="text-slate-300 hidden md:block" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>

          <div class="flex flex-col items-center text-center gap-3">
            <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M9 8h1"/><path d="M9 12h1"/><path d="M9 16h1"/><path d="M14 8h1"/><path d="M14 12h1"/><path d="M14 16h1"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>
            </div>
            <span class="font-semibold text-slate-800 text-sm">Koperasi Desa</span>
          </div>

          <svg class="text-slate-300 hidden md:block" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>

          <div class="flex flex-col items-center text-center gap-3">
            <div class="w-16 h-16 bg-blue-50 text-[#0f3e68] rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-9l-5-1H14"/><path d="M14 17h1"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
            </div>
            <span class="font-semibold text-slate-800 text-sm">Cold Chain</span>
          </div>

          <svg class="text-slate-300 hidden md:block" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>

          <div class="flex flex-col items-center text-center gap-3">
            <div class="w-16 h-16 bg-blue-50 text-[#0f3e68] rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            </div>
            <span class="font-semibold text-slate-800 text-sm">Marketplace</span>
          </div>

          <svg class="text-slate-300 hidden md:block" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>

          <div class="flex flex-col items-center text-center gap-3">
            <div class="w-16 h-16 bg-blue-50 text-[#0f3e68] rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <span class="font-semibold text-slate-800 text-sm">Pembeli</span>
          </div>
        </div>

        {/* The reverse loop arrow */}
        <div class="mt-8 flex items-center justify-center relative px-12 hidden md:flex">
          <div class="absolute inset-x-20 top-1/2 h-[1px] border-t-2 border-dashed border-emerald-400"></div>
          <div class="bg-emerald-500 rounded-full py-2 px-6 flex items-center gap-2 z-10 shadow-lg text-white font-medium text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
            Eco Point & Daur Ulang
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
